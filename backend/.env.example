# Porta em que a API vai rodar
PORT=4300

# Segredo usado para assinar os tokens JWT — troque por um valor aleatório em produção
JWT_SECRET=troque-por-um-valor-aleatorio-longo

# Banco de dados hospedado (Turso). Deixe as duas linhas abaixo vazias/removidas
# para usar um arquivo SQLite local (bom para desenvolvimento).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
